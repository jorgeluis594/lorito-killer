# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lorito_killer"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"
BULLMQ_JOB_PREFIX="local"

# Redis TLS
# Set to false only when using a self-signed Redis TLS certificate.
REDIS_TLS_REJECT_UNAUTHORIZED=true

# New Relic APM
NEW_RELIC_ENABLED=true
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=lorito-killer-local

# Better Stack Logs
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGESTING_HOST=
BETTER_STACK_LOG_LEVEL=warn

# Discord Notifications
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Admin
ADMIN_EMAIL="admin@example.com"

# Maintenance
MAINTENANCE_MODE=false

# Other existing environment variables...

# Realtime Configuration
NEXT_PUBLIC_REALTIME_PROVIDER=supabase

# Supabase Realtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
